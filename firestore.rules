rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'nikhilnuguri2007@gmail.com' ||
        request.auth.token.email == 'admin@evntly.app'
      );
    }

    // Helper to check if user is the owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Live Events Collection
    match /events/{eventId} {
      allow read: if true; // Everyone can see live events
      allow create, update, delete: if isAdmin();
    }

    // Pending Events (Submissions)
    match /pending_events/{eventId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.submittedBy == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (request.auth != null && resource.data.submittedBy == request.auth.uid);
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if isAdmin(); // Only admins/system can send notifications
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
